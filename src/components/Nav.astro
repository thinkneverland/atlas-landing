---

---

<header
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 border-b border-transparent transition-all duration-300 nav-blur"
  style="background-color: rgba(8,12,32,0);"
>
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between relative">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-3 group">
      <svg
        width="32"
        height="32"
        viewBox="0 0 32 32"
        xmlns="http://www.w3.org/2000/svg"
        class="flex-shrink-0"
      >
        <circle
          cx="16"
          cy="16"
          r="15.5"
          fill="#0d1133"
          stroke="#d4a853"
          stroke-width="1"></circle>
        <circle
          cx="16"
          cy="16"
          r="10"
          fill="none"
          stroke="rgba(212,168,83,0.3)"
          stroke-width="0.5"></circle>
        <polygon points="16,3 14.5,13 16,14.5 17.5,13" fill="#d4a853"></polygon>
        <polygon points="16,29 14.5,19 16,17.5 17.5,19" fill="#a07830"
        ></polygon>
        <polygon points="29,16 19,14.5 17.5,16 19,17.5" fill="#a07830"
        ></polygon>
        <polygon points="3,16 13,14.5 14.5,16 13,17.5" fill="#a07830"></polygon>
        <circle cx="16" cy="16" r="2" fill="#d4a853"></circle>
      </svg>
      <span
        class="font-heading font-bold text-lg tracking-wider"
        style="color:#d4a853;">AtlasMCP</span
      >
    </a>

    <!-- Desktop nav links — centered to page, not siblings -->
    <nav class="hidden md:flex items-center gap-8 absolute left-1/2 -translate-x-1/2">
      {
        [
          ["Features", "#features"],
          ["Install", "#install"],
          ["IDE Setup", "#ide-setup"],
          ["CLI", "#cli"],
          ["Tools", "#tools"],
        ].map(([label, href]) => (
          <a
            href={href}
            class="font-heading text-xs tracking-widest uppercase transition-colors duration-200"
            style="color:rgba(196,182,154,0.7);"
            onmouseover="this.style.color='#d4a853'"
            onmouseout="this.style.color='rgba(196,182,154,0.7)'"
          >
            {label}
          </a>
        ))
      }
    </nav>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      <!-- Mobile menu toggle -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg"
        style="color:#d4a853;"
        aria-label="Toggle menu"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t px-6 py-4 space-y-3"
    style="border-color:rgba(212,168,83,0.15);background:rgba(8,12,32,0.96);"
  >
    {
      [
        ["Features", "#features"],
        ["Install", "#install"],
        ["IDE Setup", "#ide-setup"],
        ["CLI Reference", "#cli"],
        ["MCP Tools", "#tools"],
      ].map(([label, href]) => (
        <a
          href={href}
          class="block font-heading text-sm tracking-wider py-2 transition-colors"
          style="color:#c4b69a;"
        >
          {label}
        </a>
      ))
    }
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
  // Close on link click
  menu?.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => menu.classList.add("hidden"));
  });
</script>
