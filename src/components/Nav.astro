---
---
<header
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 border-b border-transparent transition-all duration-300 nav-blur"
  style="background-color: rgba(8,12,32,0);"
>
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-3 group">
      <svg width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" class="flex-shrink-0">
        <circle cx="16" cy="16" r="15.5" fill="#0d1133" stroke="#d4a853" stroke-width="1"/>
        <circle cx="16" cy="16" r="10" fill="none" stroke="rgba(212,168,83,0.3)" stroke-width="0.5"/>
        <polygon points="16,3 14.5,13 16,14.5 17.5,13" fill="#d4a853"/>
        <polygon points="16,29 14.5,19 16,17.5 17.5,19" fill="#a07830"/>
        <polygon points="29,16 19,14.5 17.5,16 19,17.5" fill="#a07830"/>
        <polygon points="3,16 13,14.5 14.5,16 13,17.5" fill="#a07830"/>
        <circle cx="16" cy="16" r="2" fill="#d4a853"/>
      </svg>
      <span
        class="font-heading font-bold text-lg tracking-wider"
        style="color:#d4a853;"
      >AtlasMCP</span>
    </a>

    <!-- Desktop nav links -->
    <nav class="hidden md:flex items-center gap-8">
      {[
        ['Features', '#features'],
        ['Install', '#install'],
        ['IDE Setup', '#ide-setup'],
        ['CLI', '#cli'],
        ['Tools', '#tools'],
      ].map(([label, href]) => (
        <a
          href={href}
          class="font-heading text-xs tracking-widest uppercase transition-colors duration-200"
          style="color:rgba(196,182,154,0.7);"
          onmouseover="this.style.color='#d4a853'"
          onmouseout="this.style.color='rgba(196,182,154,0.7)'"
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      <a
        href="https://github.com/thinkneverland/atlas-mcp"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:flex items-center gap-2 px-4 py-2 rounded-lg border font-heading text-xs tracking-widest uppercase transition-all duration-200"
        style="border-color:rgba(212,168,83,0.35);color:#d4a853;background:rgba(212,168,83,0.05);"
        onmouseover="this.style.background='rgba(212,168,83,0.12)';this.style.borderColor='rgba(212,168,83,0.6)';"
        onmouseout="this.style.background='rgba(212,168,83,0.05)';this.style.borderColor='rgba(212,168,83,0.35)';"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
      </a>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg"
        style="color:#d4a853;"
        aria-label="Toggle menu"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t px-6 py-4 space-y-3"
    style="border-color:rgba(212,168,83,0.15);background:rgba(8,12,32,0.96);"
  >
    {[
      ['Features', '#features'],
      ['Install', '#install'],
      ['IDE Setup', '#ide-setup'],
      ['CLI Reference', '#cli'],
      ['MCP Tools', '#tools'],
    ].map(([label, href]) => (
      <a
        href={href}
        class="block font-heading text-sm tracking-wider py-2 transition-colors"
        style="color:#c4b69a;"
      >
        {label}
      </a>
    ))}
    <a
      href="https://github.com/thinkneverland/atlas-mcp"
      target="_blank"
      rel="noopener noreferrer"
      class="block font-heading text-sm tracking-wider py-2"
      style="color:#d4a853;"
    >
      GitHub →
    </a>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  // Close on link click
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => menu.classList.add('hidden'));
  });
</script>
