---

<section id="features" class="relative py-28 px-6">
  <!-- Section label -->
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16 fade-in">
      <!-- Map legend badge -->
      <div class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded border"
        style="border-color:rgba(212,168,83,0.25);background:rgba(212,168,83,0.05);">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="#d4a853">
          <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/>
        </svg>
        <span class="font-heading text-xs tracking-widest uppercase" style="color:#d4a853;">Map Legend</span>
      </div>
      <h2 class="section-title text-4xl md:text-5xl mb-4 gold-text">What's in the Atlas</h2>
      <p class="font-body text-lg max-w-2xl mx-auto" style="color:#c4b69a;">
        Eighteen tools. One server. Every capability your AI needs to navigate your codebase like a seasoned cartographer.
      </p>
    </div>

    <!-- Feature cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {features.map((f, i) => (
        <div
          class="atlas-card p-6 fade-in group"
          style={`animation-delay:${i * 0.06}s;`}
        >
          <!-- Top row: numeral + icon -->
          <div class="flex items-start justify-between mb-4">
            <span
              class="font-display font-black text-3xl leading-none"
              style={`color:rgba(${f.color === '#d4a853' ? '212,168,83' : '45,212,191'},0.25);`}
            >
              {f.numeral}
            </span>
            <div style={`color:${f.color};`} set:html={f.icon}/>
          </div>

          <!-- Tag -->
          <div class="mb-2">
            <span
              class="font-heading text-xs tracking-widest uppercase"
              style={`color:${f.color};opacity:0.8;`}
            >
              {f.tag}
            </span>
          </div>

          <!-- Title -->
          <h3 class="font-heading font-bold text-base mb-3 leading-snug" style="color:#f5e6c8;">
            {f.title}
          </h3>

          <!-- Description -->
          <p class="font-body text-sm leading-relaxed" style="color:#9a8f7a;">
            {f.description}
          </p>
        </div>
      ))}
    </div>
  </div>

  <!-- Trail divider -->
  <div class="trail-divider mt-20">
    {Array.from({length: 15}).map((_, i) => (
      <>
        <span class="trail-dot" style={`animation-delay:${i * 0.15}s;`}/>
        {i < 14 && <span class="trail-line"/>}
      </>
    ))}
  </div>
</section>
