---
const toolGroups = [
  {
    label: 'Docs & Playbooks',
    color: '#d4a853',
    tools: [
      { name: 'get_doc', desc: 'Get full content, a specific phase, or a named section of any doc' },
      { name: 'search_docs', desc: 'Search by keyword, or omit query to list all docs. Supports tag filtering' },
      { name: 'run_playbook', desc: 'Start, advance, or jump to a phase. action: "start" | "next" | "jump"' },
    ],
  },
  {
    label: 'Session State',
    color: '#2dd4bf',
    tools: [
      { name: 'start_session', desc: 'Begin a session, load active context and open tasks' },
      { name: 'end_session', desc: 'Close a session with a summary' },
      { name: 'get_project_context', desc: 'Full project snapshot. Sections: session, tasks, decisions, context, tech_stack, briefing' },
      { name: 'read_state', desc: 'Read decisions, progress, context, or tech stack' },
      { name: 'update_state', desc: 'Create, update, or delete state entries' },
    ],
  },
  {
    label: 'Sync & Rebuild',
    color: '#d4a853',
    tools: [
      { name: 'sync_changes', desc: 'Sync state from git diff, or dryRun: true to preview without applying' },
      { name: 'rebuild', desc: 'Force full reindex of docs, dep graph, git, DB cache, tech stack, and enrichment' },
    ],
  },
  {
    label: 'Dependency Analysis',
    color: '#2dd4bf',
    tools: [
      { name: 'analyze_deps', desc: 'type: "blast" (what breaks), "imports" (what it depends on), "orphans" (dead code)' },
    ],
  },
  {
    label: 'Code Intelligence',
    color: '#d4a853',
    tools: [
      { name: 'get_code_intel', desc: 'type: "symbols" (project-wide), "exports" (single file), "types" (interfaces/enums)' },
      { name: 'get_project_surface', desc: 'type: "routes", "schema", "env", "contracts", "impact" (route↔table), "domain" (roles/auth/entities)' },
      { name: 'get_project_health', desc: 'type: "hotspots" (risky files), "coverage" (untested), "security" (sensitive), "errors" (anti-patterns)' },
      { name: 'get_test_patterns', desc: 'Test framework, naming conventions, describe blocks, setup patterns' },
      { name: 'get_project_map', desc: 'type: "workspace" (monorepo), "graph" (cross-package deps), "velocity" (commits), "explain" (diff summary)' },
    ],
  },
  {
    label: 'DB Introspection (optional)',
    color: '#2dd4bf',
    tools: [
      { name: 'inspect_schema', desc: 'mode: "tables" (list all), "describe" (columns/indexes/FKs), "search" (find by name). Enabled via ATLAS_DB_URL' },
      { name: 'run_readonly_query', desc: 'Execute a read-only SQL query. Requires ATLAS_DB_ALLOW_QUERY=true. Mutations strictly blocked' },
    ],
  },
  {
    label: 'System',
    color: '#d4a853',
    tools: [
      { name: 'server_status', desc: 'Version, uptime, docs loaded, DB status, git info, and active session' },
    ],
  },
];

const resources = [
  { uri: 'atlas://active-context', desc: 'Current project context entries (active key/value state)' },
  { uri: 'atlas://recent-decisions', desc: 'Last 5 architectural decisions recorded for the project' },
  { uri: 'atlas://open-tasks', desc: 'Currently in-progress and blocked tasks' },
];
---

<section id="tools" class="relative py-28 px-6">
  <div class="max-w-5xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-14 fade-in">
      <div class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded border"
        style="border-color:rgba(212,168,83,0.25);background:rgba(212,168,83,0.05);">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#d4a853" stroke-width="2">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
        </svg>
        <span class="font-heading text-xs tracking-widest uppercase" style="color:#d4a853;">MCP Tools</span>
      </div>
      <h2 class="section-title text-4xl md:text-5xl mb-4 gold-text">18 Tools. One Server.</h2>
      <p class="font-body text-lg max-w-xl mx-auto" style="color:#c4b69a;">
        Every tool description starts with "Use when…" for LLM discoverability. Your AI knows exactly when to reach for the atlas.
      </p>
    </div>

    <!-- Tool groups -->
    <div class="space-y-6 fade-in">
      {toolGroups.map((group) => (
        <div class="atlas-card overflow-hidden">
          <div class="flex items-center gap-3 px-6 py-3 border-b"
            style={`border-color:rgba(212,168,83,0.1);background:rgba(${group.color === '#d4a853' ? '212,168,83' : '45,212,191'},0.05);`}>
            <span class="w-2 h-2 rounded-full flex-shrink-0"
              style={`background:${group.color};`}></span>
            <span class="font-heading font-bold text-sm" style={`color:${group.color};`}>{group.label}</span>
            <span class="font-heading text-xs ml-auto" style="color:rgba(196,182,154,0.4);">
              {group.tools.length} {group.tools.length === 1 ? 'tool' : 'tools'}
            </span>
          </div>
          <table class="w-full text-sm">
            <tbody>
              {group.tools.map((tool, i) => (
                <tr
                  class="transition-colors"
                  style={`border-bottom:${i < group.tools.length - 1 ? '1px solid rgba(30,45,92,0.4)' : 'none'};`}
                  onmouseover="this.style.background='rgba(212,168,83,0.03)'"
                  onmouseout="this.style.background='transparent'"
                >
                  <td class="px-6 py-3 font-mono text-xs align-top" style="color:#2dd4bf;white-space:nowrap;width:35%;">
                    {tool.name}
                  </td>
                  <td class="px-6 py-3 font-body text-sm leading-relaxed" style="color:#9a8f7a;">{tool.desc}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ))}
    </div>

    <!-- MCP Resources -->
    <div class="mt-10 fade-in">
      <div class="atlas-card overflow-hidden">
        <div class="px-6 py-4 border-b" style="border-color:rgba(212,168,83,0.12);background:rgba(45,212,191,0.04);">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-teal flex-shrink-0"></span>
            <h3 class="font-heading font-bold text-sm" style="color:#2dd4bf;">MCP Resources</h3>
            <span class="font-body text-xs ml-2" style="color:rgba(196,182,154,0.5);">Passively surfaced — no tool call required</span>
          </div>
        </div>
        <table class="w-full text-sm">
          <tbody>
            {resources.map((r, i) => (
              <tr
                class="transition-colors"
                style={`border-bottom:${i < resources.length - 1 ? '1px solid rgba(30,45,92,0.3)' : 'none'};`}
                onmouseover="this.style.background='rgba(45,212,191,0.03)'"
                onmouseout="this.style.background='transparent'"
              >
                <td class="px-6 py-3 font-mono text-xs align-top" style="color:#2dd4bf;white-space:nowrap;width:40%;">{r.uri}</td>
                <td class="px-6 py-3 font-body text-sm" style="color:#9a8f7a;">{r.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Trail divider -->
  <div class="trail-divider mt-20">
    {Array.from({length: 15}).map((_, i) => (
      <>
        <span class="trail-dot" style={`animation-delay:${i * 0.15}s;`}/>
        {i < 14 && <span class="trail-line"/>}
      </>
    ))}
  </div>
</section>
