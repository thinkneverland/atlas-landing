---
---
<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden map-grid pt-16"
>
  <!-- Compass rose decorative (large, right side) -->
  <div
    aria-hidden="true"
    class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/3 w-[600px] h-[600px] opacity-20 pointer-events-none"
  >
    <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" width="600" height="600">
      <!-- Outer rings -->
      <circle cx="200" cy="200" r="195" fill="none" stroke="#d4a853" stroke-width="0.5" stroke-dasharray="4 8"/>
      <circle cx="200" cy="200" r="170" fill="none" stroke="#d4a853" stroke-width="0.3"/>
      <circle cx="200" cy="200" r="120" fill="none" stroke="#d4a853" stroke-width="0.5" stroke-dasharray="2 4"/>
      <circle cx="200" cy="200" r="60" fill="none" stroke="#d4a853" stroke-width="0.5"/>
      <circle cx="200" cy="200" r="20" fill="none" stroke="#d4a853" stroke-width="1"/>

      <!-- Cross hairs -->
      <line x1="200" y1="5" x2="200" y2="395" stroke="#d4a853" stroke-width="0.3" opacity="0.4"/>
      <line x1="5" y1="200" x2="395" y2="200" stroke="#d4a853" stroke-width="0.3" opacity="0.4"/>
      <line x1="30" y1="30" x2="370" y2="370" stroke="#d4a853" stroke-width="0.2" opacity="0.25"/>
      <line x1="370" y1="30" x2="30" y2="370" stroke="#d4a853" stroke-width="0.2" opacity="0.25"/>

      <!-- Degree marks every 30deg -->
      <g id="outer-marks">
        {Array.from({length: 12}).map((_, i) => {
          const angle = (i * 30 * Math.PI) / 180;
          const x1 = 200 + 170 * Math.sin(angle);
          const y1 = 200 - 170 * Math.cos(angle);
          const x2 = 200 + 183 * Math.sin(angle);
          const y2 = 200 - 183 * Math.cos(angle);
          return <line x1={x1} y1={y1} x2={x2} y2={y2} stroke="#d4a853" stroke-width="1"/>;
        })}
      </g>

      <!-- Cardinal points (N/S/E/W) - large kite shapes -->
      <!-- N -->
      <polygon points="200,8 188,155 200,172 212,155" fill="#d4a853"/>
      <!-- S -->
      <polygon points="200,392 188,245 200,228 212,245" fill="#a07830" opacity="0.7"/>
      <!-- E -->
      <polygon points="392,200 245,188 228,200 245,212" fill="#a07830" opacity="0.7"/>
      <!-- W -->
      <polygon points="8,200 155,188 172,200 155,212" fill="#a07830" opacity="0.7"/>

      <!-- Intercardinal points (NE/NW/SE/SW) -->
      <polygon points="200,8 188,155 200,172 212,155" fill="#c8922a" opacity="0.5"
        transform="rotate(45 200 200) scale(0.65) translate(56 56)"/>
      <g transform="rotate(45, 200, 200)">
        <polygon points="200,40 193,130 200,142 207,130" fill="#c8922a" opacity="0.45"/>
      </g>
      <g transform="rotate(135, 200, 200)">
        <polygon points="200,40 193,130 200,142 207,130" fill="#c8922a" opacity="0.35"/>
      </g>
      <g transform="rotate(225, 200, 200)">
        <polygon points="200,40 193,130 200,142 207,130" fill="#c8922a" opacity="0.35"/>
      </g>
      <g transform="rotate(315, 200, 200)">
        <polygon points="200,40 193,130 200,142 207,130" fill="#c8922a" opacity="0.45"/>
      </g>

      <!-- Cardinal letters -->
      <text x="200" y="200" text-anchor="middle" font-family="Cinzel, serif" font-size="18" fill="#f0c165" font-weight="700"
        transform="translate(0,-150)">N</text>
      <text x="200" y="200" text-anchor="middle" font-family="Cinzel, serif" font-size="14" fill="#a07830"
        transform="translate(0,162)">S</text>
      <text x="200" y="200" text-anchor="middle" font-family="Cinzel, serif" font-size="14" fill="#a07830"
        transform="translate(162,5)">E</text>
      <text x="200" y="200" text-anchor="middle" font-family="Cinzel, serif" font-size="14" fill="#a07830"
        transform="translate(-162,5)">W</text>

      <!-- Center -->
      <circle cx="200" cy="200" r="8" fill="#d4a853"/>
      <circle cx="200" cy="200" r="4" fill="#080c20"/>
      <circle cx="200" cy="200" r="2" fill="#d4a853"/>
    </svg>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border mb-8 fade-in"
      style="border-color:rgba(212,168,83,0.35);background:rgba(212,168,83,0.07);">
      <span class="w-1.5 h-1.5 rounded-full bg-gold animate-pulse"></span>
      <span class="font-heading text-xs tracking-widest uppercase" style="color:#d4a853;">
        Universal MCP Server · v2.5
      </span>
    </div>

    <!-- Headline -->
    <h1
      class="font-display font-black mb-6 leading-none fade-in"
      style="font-size:clamp(3rem,8vw,6rem);animation-delay:0.1s;"
    >
      <span class="gold-text">Chart Your</span><br/>
      <span style="color:#f5e6c8;">Codebase</span>
    </h1>

    <!-- Subheadline -->
    <p
      class="font-body text-xl max-w-2xl mx-auto mb-10 leading-relaxed fade-in"
      style="color:#c4b69a;animation-delay:0.2s;"
    >
      The universal MCP server for AI-assisted development. Serves docs, manages session state,
      runs playbooks, syncs from git diffs, and maps your entire project — in any IDE, any language.
    </p>

    <!-- Install command terminal -->
    <div
      id="install"
      class="terminal max-w-xl mx-auto mb-8 fade-in text-left"
      style="animation-delay:0.3s;"
    >
      <div class="terminal-bar">
        <span class="terminal-dot" style="background:#c0392b;"></span>
        <span class="terminal-dot" style="background:#d4a853;"></span>
        <span class="terminal-dot" style="background:#2dd4bf;"></span>
        <span class="ml-2 font-mono text-xs" style="color:rgba(196,182,154,0.5);">terminal</span>
      </div>
      <div class="px-5 py-4 space-y-2 font-mono text-sm">
        <div class="flex items-center gap-3">
          <span style="color:#d4a853;">$</span>
          <span style="color:#f5e6c8;">npm install -g @thinkneverland/atlas-mcp</span>
        </div>
        <div class="flex items-center gap-3">
          <span style="color:#d4a853;">$</span>
          <span style="color:#2dd4bf;">atlas init</span>
        </div>
        <div class="flex items-center gap-3">
          <span style="color:#d4a853;">$</span>
          <span style="color:#2dd4bf;">atlas status</span>
        </div>
      </div>
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 fade-in" style="animation-delay:0.4s;">
      <a
        href="#features"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl font-heading text-sm tracking-widest uppercase transition-all duration-300 glow-gold"
        style="background:linear-gradient(135deg,#a07830,#d4a853,#f0c165,#d4a853,#a07830);background-size:200%;color:#080c20;font-weight:700;"
        onmouseover="this.style.backgroundPosition='100%';this.style.transform='translateY(-2px)';"
        onmouseout="this.style.backgroundPosition='0%';this.style.transform='translateY(0)';"
      >
        Start Exploring
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
      </a>
      <a
        href="https://github.com/thinkneverland/atlas-mcp"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl border font-heading text-sm tracking-widest uppercase transition-all duration-300"
        style="border-color:rgba(212,168,83,0.35);color:#d4a853;background:rgba(212,168,83,0.05);"
        onmouseover="this.style.borderColor='rgba(212,168,83,0.7)';this.style.background='rgba(212,168,83,0.1)';this.style.transform='translateY(-2px)';"
        onmouseout="this.style.borderColor='rgba(212,168,83,0.35)';this.style.background='rgba(212,168,83,0.05)';this.style.transform='translateY(0)';"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        View on GitHub
      </a>
    </div>

    <!-- Scroll hint -->
    <div class="mt-16 fade-in" style="animation-delay:0.6s;">
      <div class="flex flex-col items-center gap-2 opacity-40">
        <span class="font-heading text-xs tracking-widest uppercase" style="color:#d4a853;">Scroll to explore</span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4a853" stroke-width="1.5" class="animate-bounce">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
      </div>
    </div>
  </div>
</section>
