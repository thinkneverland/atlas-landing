---
const ides = [
  {
    id: 'windsurf',
    label: 'Windsurf',
    configPath: '~/.codeium/windsurf/mcp_config.json',
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    config: `{
  "mcpServers": {
    "atlas-mcp": {
      "command": "atlas-mcp",
      "args": [],
      "env": {
        "ATLAS_DOCS_DIR": ".atlas"
      }
    }
  }
}`,
    rulesFile: '.windsurfrules',
  },
  {
    id: 'cursor',
    label: 'Cursor',
    configPath: '~/.cursor/mcp.json',
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
    config: `{
  "mcpServers": {
    "atlas-mcp": {
      "command": "atlas-mcp",
      "args": [],
      "env": {
        "ATLAS_DOCS_DIR": ".atlas"
      }
    }
  }
}`,
    rulesFile: '.cursorrules',
  },
  {
    id: 'vscode',
    label: 'VS Code + Cline',
    configPath: 'Cline MCP Settings',
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    config: `{
  "mcpServers": {
    "atlas-mcp": {
      "command": "atlas-mcp",
      "args": [],
      "env": {
        "ATLAS_DOCS_DIR": ".atlas"
      }
    }
  }
}`,
    rulesFile: null,
  },
  {
    id: 'zed',
    label: 'Zed',
    configPath: 'settings.json',
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 17L17 7M7 7h10v10"/></svg>`,
    config: `{
  "context_servers": {
    "atlas-mcp": {
      "command": {
        "path": "atlas-mcp",
        "args": []
      }
    }
  }
}`,
    rulesFile: null,
  },
  {
    id: 'continue',
    label: 'VS Code + Continue',
    configPath: '.continue/config.json',
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>`,
    config: `{
  "experimental": {
    "modelContextProtocolServers": [
      {
        "transport": {
          "type": "stdio",
          "command": "atlas-mcp",
          "args": []
        }
      }
    ]
  }
}`,
    rulesFile: null,
  },
];
---

<section id="ide-setup" class="relative py-28 px-6" style="background:rgba(13,17,51,0.4);">
  <div class="max-w-5xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-14 fade-in">
      <div class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded border"
        style="border-color:rgba(212,168,83,0.25);background:rgba(212,168,83,0.05);">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#d4a853" stroke-width="2">
          <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
        <span class="font-heading text-xs tracking-widest uppercase" style="color:#d4a853;">IDE Configuration</span>
      </div>
      <h2 class="section-title text-4xl md:text-5xl mb-4 gold-text">Configure Your IDE</h2>
      <p class="font-body text-lg max-w-xl mx-auto" style="color:#c4b69a;">
        AtlasMCP works with every major AI IDE. Pick yours and paste the config.
      </p>

      <!-- Important note -->
      <div class="mt-6 inline-flex items-start gap-3 text-left px-5 py-4 rounded-lg border max-w-xl"
        style="border-color:rgba(212,168,83,0.25);background:rgba(212,168,83,0.05);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d4a853" stroke-width="2" class="flex-shrink-0 mt-0.5">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <p class="font-body text-sm" style="color:#c4b69a;">
          <strong style="color:#d4a853;">Important:</strong> Always use the globally installed <code>atlas-mcp</code> binary — not <code>npx</code>. Native modules require a stable install path.
        </p>
      </div>
    </div>

    <!-- Tabs -->
    <div class="fade-in">
      <!-- Tab buttons -->
      <div class="flex flex-wrap gap-2 mb-6">
        {ides.map((ide, i) => (
          <button
            class="tab-btn px-4 py-2 rounded-lg border text-xs font-heading tracking-widest uppercase"
            data-tab={ide.id}
            style={`border-color:${i === 0 ? 'rgba(212,168,83,0.6)' : 'rgba(212,168,83,0.2)'};
                    background:${i === 0 ? 'rgba(212,168,83,0.12)' : 'rgba(212,168,83,0.04)'};
                    color:${i === 0 ? '#d4a853' : 'rgba(196,182,154,0.6)'};`}
          >
            <span set:html={ide.icon} style="display:inline-flex;vertical-align:middle;margin-right:6px;"/>
            {ide.label}
          </button>
        ))}
      </div>

      <!-- Tab content panels -->
      {ides.map((ide, i) => (
        <div
          id={`tab-${ide.id}`}
          class={`tab-content${i === 0 ? ' active' : ''}`}
        >
          <div class="atlas-card overflow-hidden">
            <!-- Config file path header -->
            <div class="flex items-center justify-between px-5 py-3 border-b"
              style="border-color:rgba(212,168,83,0.12);background:rgba(8,12,32,0.5);">
              <span class="font-mono text-xs" style="color:rgba(196,182,154,0.5);">
                {ide.configPath}
              </span>
              <button
                class="copy-btn font-heading text-xs tracking-widest uppercase px-3 py-1 rounded border transition-all"
                style="border-color:rgba(212,168,83,0.25);color:#d4a853;background:rgba(212,168,83,0.05);"
                data-code={ide.config}
              >
                Copy
              </button>
            </div>
            <pre class="m-0 rounded-none border-0" style="background:transparent;"><code style="color:#f5e6c8;">{ide.config}</code></pre>
          </div>

          {ide.rulesFile && (
            <div class="mt-5 atlas-card p-5">
              <div class="flex items-start gap-3">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2dd4bf" stroke-width="2" class="flex-shrink-0 mt-0.5">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
                </svg>
                <div>
                  <p class="font-heading text-sm font-bold mb-1" style="color:#2dd4bf;">
                    Recommended: Add IDE Rules
                  </p>
                  <p class="font-body text-sm mb-3" style="color:#9a8f7a;">
                    Create <code>{ide.rulesFile}</code> in your project root to make Atlas tools automatic on every AI session. Get the template via:
                  </p>
                  <div class="terminal">
                    <div class="terminal-bar">
                      <span class="terminal-dot" style="background:#c0392b;"></span>
                      <span class="terminal-dot" style="background:#d4a853;"></span>
                      <span class="terminal-dot" style="background:#2dd4bf;"></span>
                    </div>
                    <div class="px-4 py-3 font-mono text-sm flex items-center gap-2">
                      <span style="color:#d4a853;">$</span>
                      <span style="color:#2dd4bf;">atlas docs show ide-rules</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>

  <!-- Trail divider -->
  <div class="trail-divider mt-20">
    {Array.from({length: 15}).map((_, i) => (
      <>
        <span class="trail-dot" style={`animation-delay:${i * 0.15}s;`}/>
        {i < 14 && <span class="trail-line"/>}
      </>
    ))}
  </div>
</section>

<script>
  // Tab switching
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const tabPanels = document.querySelectorAll<HTMLElement>('.tab-content');

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab;

      tabBtns.forEach((b) => {
        const active = b.dataset.tab === target;
        b.style.borderColor = active ? 'rgba(212,168,83,0.6)' : 'rgba(212,168,83,0.2)';
        b.style.background = active ? 'rgba(212,168,83,0.12)' : 'rgba(212,168,83,0.04)';
        b.style.color = active ? '#d4a853' : 'rgba(196,182,154,0.6)';
      });

      tabPanels.forEach((p) => {
        p.classList.toggle('active', p.id === `tab-${target}`);
      });
    });
  });

  // Copy buttons
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const code = btn.dataset.code || '';
      await navigator.clipboard.writeText(code);
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      btn.style.borderColor = 'rgba(45,212,191,0.6)';
      btn.style.color = '#2dd4bf';
      setTimeout(() => {
        btn.textContent = orig;
        btn.style.borderColor = 'rgba(212,168,83,0.25)';
        btn.style.color = '#d4a853';
      }, 1800);
    });
  });
</script>
